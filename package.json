{
  "name": "api-regressor99",
  "version": "0.1.0",
  "private": true,
  "description": "Continuous API performance regression detection platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate -w @regressor99/api",
    "db:seed": "npm run prisma:seed -w @regressor99/api",
    "db:reset": "npm run db:reset -w @regressor99/api",
    "db:studio": "npm run prisma:studio -w @regressor99/api",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}

